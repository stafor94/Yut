{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".tmp-unit-tests",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/features/items/logic/items.ts",
    "src/features/room/services/roomAuthoritativeReducer.ts",
    "src/game-core/board/board.ts",
    "src/game-core/gameEngine.ts",
    "src/game-core/roll.ts",
    "src/app/hooks/gameSyncSubscription.ts",
    "tests/unit/**/*.ts",
    "src/app/diagnostics/gameDiagnostics.ts"
  ]
}
