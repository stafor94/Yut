{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".tmp-unit-tests",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/features/items/logic/items.ts",
    "src/features/room/hooks/roomListSubscription.ts",
    "src/features/room/services/roomAvailabilityPolicy.ts",
    "src/features/room/services/roomCreationCleanup.ts",
    "src/features/room/services/roomLifecyclePolicy.ts",
    "src/features/room/services/roomAuthoritativeReducer.ts",
    "src/features/room/services/roomPresenceCleanupPolicy.ts",
    "src/features/room/services/roomGamePreparationPolicy.ts",
    "src/features/room/services/roomTiming.ts",
    "src/game-core/aiDifficulty.ts",
    "src/game-core/aiStrategy.ts",
    "src/game-core/board/board.ts",
    "src/game-core/gameEngine.ts",
    "src/game-core/roll.ts",
    "src/app/hooks/gameSyncSubscription.ts",
    "src/app/hooks/sequenceRecoveryWatchdog.ts",
    "src/app/flows/roomCreationFlow.ts",
    "src/app/flows/presenceRecovery.ts",
    "src/app/flows/onlineGameCoordinator.ts",
    "src/app/flows/actionFeedback.ts",
    "src/app/flows/gameStartPreparation.ts",
    "src/app/flows/turnOrderFlow.ts",
    "src/app/flows/turnOrderPresentation.ts",
    "src/services/firebase/firebaseAuthRetry.ts",
    "tests/unit/**/*.ts",
    "src/app/diagnostics/gameDiagnostics.ts"
  ]
}
