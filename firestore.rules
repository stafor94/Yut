rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function playerPath(roomId, playerId) {
      return /databases/$(database)/documents/rooms/$(roomId)/players/$(playerId);
    }

    function gameStatePath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId)/state/current;
    }

    function roomExists(roomId) {
      return exists(roomPath(roomId));
    }

    function roomExistsAfter(roomId) {
      return existsAfter(roomPath(roomId));
    }

    function isRoomHost(roomId) {
      return signedIn()
        && roomExists(roomId)
        && get(roomPath(roomId)).data.hostId == request.auth.uid;
    }

    function isRoomHostAfter(roomId) {
      return signedIn()
        && roomExistsAfter(roomId)
        && getAfter(roomPath(roomId)).data.hostId == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return signedIn() && exists(playerPath(roomId, request.auth.uid));
    }

    function isRoomMemberAfter(roomId) {
      return signedIn() && existsAfter(playerPath(roomId, request.auth.uid));
    }

    function isActiveRoomMember(roomId) {
      return isRoomMember(roomId)
        && get(playerPath(roomId, request.auth.uid)).data.isSpectator != true;
    }

    function isActiveRoomMemberAfter(roomId) {
      return isRoomMemberAfter(roomId)
        && getAfter(playerPath(roomId, request.auth.uid)).data.isSpectator != true;
    }

    function isPresenceCleanupLeaseOwner(roomId) {
      return signedIn()
        && isRoomMember(roomId)
        && get(roomPath(roomId)).data.presenceCleanupLeaseOwnerId == request.auth.uid;
    }

    function canReadRoomData(roomId) {
      return isRoomMember(roomId);
    }

    function canWriteRoomData(roomId) {
      return isActiveRoomMember(roomId)
        || isActiveRoomMemberAfter(roomId)
        || isRoomHost(roomId)
        || isRoomHostAfter(roomId);
    }

    function isGameCoordinator(roomId) {
      return signedIn()
        && exists(gameStatePath(roomId))
        && get(gameStatePath(roomId)).data.coordinatorSeatId == request.auth.uid;
    }

    function hasExpiredEmptyGrace(roomId) {
      let hasRoom = roomExists(roomId) || roomExistsAfter(roomId);
      let room = roomExists(roomId)
        ? get(roomPath(roomId)).data
        : getAfter(roomPath(roomId)).data;
      let explicitGraceExpired = ('emptySince' in room)
        && room.emptySince is timestamp
        && request.time >= room.emptySince + duration.value(3, 'm');
      let heartbeatGraceExpired = ('lastHumanSeenAt' in room)
        && room.lastHumanSeenAt is timestamp
        && request.time >= room.lastHumanSeenAt + duration.value(225, 's');
      return hasRoom && (explicitGraceExpired || heartbeatGraceExpired);
    }

    function startsEmptyRoomGrace(roomId) {
      return signedIn()
        && roomExists(roomId)
        && (
          isRoomMember(roomId)
          || isRoomMemberAfter(roomId)
          || isPresenceCleanupLeaseOwner(roomId)
        )
        && (
          !('emptySince' in resource.data)
          || resource.data.emptySince == null
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'emptySince',
          'lastActivityAt'
        ])
        && request.resource.data.emptySince == request.time
        && request.resource.data.lastActivityAt == request.time;
    }

    function isRoomMemberPresenceUpdate(roomId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && isRoomMemberAfter(roomId)
        && changedKeys.hasOnly([
          'emptySince',
          'lastHumanSeenAt',
          'lastActivityAt',
          'currentPlayers',
          'presenceCleanupLeaseOwnerId',
          'presenceCleanupLeaseExpiresAt',
          'presenceCleanupLeaseVersion',
          'presenceCleanupLeaseUpdatedAt'
        ])
        && (
          !changedKeys.hasAny(['lastHumanSeenAt'])
          || request.resource.data.lastHumanSeenAt == request.time
        )
        && (
          !changedKeys.hasAny(['emptySince'])
          || request.resource.data.emptySince == null
          || request.resource.data.emptySince == request.time
        );
    }

    function isRoomMemberExitUpdate(roomId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && isRoomMember(roomId)
        && !isRoomMemberAfter(roomId)
        && changedKeys.hasOnly([
          'emptySince',
          'deletingAt',
          'lastActivityAt',
          'currentPlayers'
        ])
        && (
          !changedKeys.hasAny(['emptySince'])
          || request.resource.data.emptySince == null
          || request.resource.data.emptySince == request.time
        );
    }

    function isExpiredRoomCleanupUpdate(roomId) {
      return signedIn()
        && hasExpiredEmptyGrace(roomId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'deletingAt',
          'lastActivityAt'
        ])
        && request.resource.data.status == 'finished'
        && request.resource.data.deletingAt == request.time
        && request.resource.data.lastActivityAt == request.time;
    }

    function isCleanupEligibleRoom(roomId) {
      let room = get(roomPath(roomId)).data;
      return roomExists(roomId)
        && (!('systemRoomType' in room) || room.systemRoomType != 'creation_lock')
        && hasExpiredEmptyGrace(roomId);
    }

    function deletingWithParentRoom(roomId) {
      return signedIn() && roomExists(roomId) && !roomExistsAfter(roomId);
    }

    function canDeleteRoomData(roomId) {
      return canWriteRoomData(roomId)
        || isPresenceCleanupLeaseOwner(roomId)
        || isCleanupEligibleRoom(roomId)
        || deletingWithParentRoom(roomId);
    }

    match /rooms/{roomId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.maxPlayers in [2, 3, 4]
        && request.resource.data.playMode in ['individual', 'team']
        && request.resource.data.pieceCount in [1, 2, 3, 4];

      allow update: if canWriteRoomData(roomId)
        || isRoomMemberPresenceUpdate(roomId)
        || isRoomMemberExitUpdate(roomId)
        || startsEmptyRoomGrace(roomId)
        || isExpiredRoomCleanupUpdate(roomId);
      allow delete: if canWriteRoomData(roomId) || isCleanupEligibleRoom(roomId);

      match /players/{playerId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && !hasExpiredEmptyGrace(roomId)
          && (
            playerId == request.auth.uid
            || isRoomHostAfter(roomId)
            || isActiveRoomMemberAfter(roomId)
          );

        allow update: if signedIn()
          && (
            isPresenceCleanupLeaseOwner(roomId)
            || (
              !hasExpiredEmptyGrace(roomId)
              && (
                playerId == request.auth.uid
                || canWriteRoomData(roomId)
              )
            )
          );

        allow delete: if signedIn()
          && (
            playerId == request.auth.uid
            || isPresenceCleanupLeaseOwner(roomId)
            || canDeleteRoomData(roomId)
          );
      }

      match /seats/{seatId} {
        allow read: if signedIn();
        allow create, update: if canWriteRoomData(roomId) || isPresenceCleanupLeaseOwner(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /state/{stateId} {
        allow read: if canReadRoomData(roomId);
        allow create, update: if canWriteRoomData(roomId) || isPresenceCleanupLeaseOwner(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /actions/{actionId} {
        allow read: if canReadRoomData(roomId);
        allow create: if canWriteRoomData(roomId)
          && request.resource.data.actorId is string;
        allow update: if canWriteRoomData(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /processedActions/{actionId} {
        allow read: if canReadRoomData(roomId);
        allow create, update: if canWriteRoomData(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /turnOrderSubmissions/{submissionId} {
        allow read: if canReadRoomData(roomId);
        allow create: if canWriteRoomData(roomId)
          && request.resource.data.sessionId is string
          && request.resource.data.roundId is string
          && request.resource.data.seatId is string
          && request.resource.data.submissionId is string
          && request.resource.data.submissionId == submissionId
          && submissionId == request.resource.data.roundId + ':' + request.resource.data.seatId
          && request.resource.data.resultName is string
          && request.resource.data.source in ['manual', 'auto']
          && request.resource.data.submittedBy == request.auth.uid
          && (
            request.resource.data.seatId == request.auth.uid
            || (
              request.resource.data.source == 'auto'
              && isGameCoordinator(roomId)
              && request.resource.data.coordinatorSeatId == request.auth.uid
            )
          );
        allow update: if false;
        allow delete: if canDeleteRoomData(roomId);
      }

      match /sequences/{sequenceId} {
        allow read: if canReadRoomData(roomId);
        allow create: if canWriteRoomData(roomId)
          && request.resource.data.sequence is int
          && request.resource.data.actorId is string;
        allow update: if canWriteRoomData(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /boardItems/{itemId} {
        allow read: if canReadRoomData(roomId);
        allow create, update: if canWriteRoomData(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /rooms/{nestedRoomId} {
        allow read: if canReadRoomData(roomId);
        allow create, update: if canWriteRoomData(roomId);
        allow delete: if canDeleteRoomData(roomId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
